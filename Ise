import os
from flask import Flask, render_template_string

app = Flask(__name__)

# Dashboard Port: 5000 | Kiwix Port: 8080
# Note: Jab aap Global URL use karenge, toh Iframe ke liye 
# humein dono ports ko tunnel karna hoga.

@app.route('/')
def dashboard():
    return render_template_string("""
    <html>
    <head>
        <title>VISHNU SUPREME : GLOBAL ACCESS</title>
        <style>
            body { background: #000; color: #0f0; font-family: 'Courier New'; margin: 0; }
            .navbar { background: #0a0a0a; border-bottom: 2px solid #0f0; padding: 15px; text-align: center; font-size: 20px; font-weight: bold; }
            .main-frame { width: 100%; height: 90vh; border: none; }
            .btn-group { padding: 10px; background: #111; text-align: center; }
            button { background: #0f0; color: #000; border: none; padding: 10px 20px; font-weight: bold; cursor: pointer; margin: 0 5px; }
        </style>
    </head>
    <body>
        <div class="navbar">[ VISHNU AGENT : GLOBAL COMMAND CENTER ]</div>
        
        <div class="btn-group">
            <button onclick="changeView('kiwix')">KNOWLEDGE BASE (KIWIX)</button>
            <button onclick="changeView('files')">FILE MANAGER</button>
            <button onclick="changeView('system')">SYSTEM STATUS</button>
        </div>

        <iframe id="content-frame" class="main-frame" src="http://localhost:8080"></iframe>

        <script>
            function changeView(type) {
                const frame = document.getElementById('content-frame');
                if(type === 'kiwix') frame.src = "http://localhost:8080";
                else if(type === 'files') alert("Accessing Agents Files...");
            }
        </script>
    </body>
    </html>
    """)

if __name__ == "__main__":
    app.run(host='0.0.0.0', port=5000)
